# ============================================================
# MedNexus — Environment Variables / Secrets
# ============================================================
# On Replit: add these in the Secrets tab (not as plain env vars).
# Locally:   copy this file to `.env.local` and fill in values.
# ============================================================

# ── DATABASE ─────────────────────────────────────────────────
# On Replit: DATABASE_URL is injected automatically by the
#            built-in PostgreSQL add-on — do NOT set manually.
# Locally:   supply a Postgres connection string (e.g. Neon free tier).
#
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# ── ADMIN PANEL ───────────────────────────────────────────────
# REQUIRED — the app will not let you log in as admin without these.
#
#   ADMIN_PASSWORD — password you type on the Admin login screen
#   ADMIN_SECRET   — random string that signs admin session tokens
#                    (generate one: openssl rand -hex 32)
#
ADMIN_PASSWORD=your-admin-password-here
ADMIN_SECRET=your-random-32-char-secret-here

# ── GEMINI AI (Word & PDF import) ────────────────────────────
# REQUIRED for AI-powered question extraction from .docx and .pdf files.
# Without this key the import still works but falls back to a basic
# regex parser — no clinical vignette grouping, no image reading.
#
# Get a free key at: https://aistudio.google.com/app/apikey
#
GEMINI_API_KEY=your-gemini-api-key-here

# ── FIREBASE (optional) ───────────────────────────────────────
# Only needed if you re-enable Firebase auth as a fallback.
# Leave commented out if you are using Replit's PostgreSQL (default).
#
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
