# ============================================================
# MedNexus — Environment Variables
# ============================================================
# Copy this file to `.env.local` and fill in the values.
#
# REQUIRED for cloud storage (PostgreSQL):
#   Sign up at https://neon.tech (free tier) or any Postgres host.
#   Then paste the connection string below.
#   On Replit, DATABASE_URL is injected automatically — no action needed.
#
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# REQUIRED for the admin panel to work:
#   ADMIN_PASSWORD — the password you enter to log in as admin
#   ADMIN_SECRET   — a random string used to sign admin session tokens
#                    (generate one with: openssl rand -hex 32)
ADMIN_PASSWORD=
ADMIN_SECRET=

# Optional — only needed if you re-enable Firebase auth.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
